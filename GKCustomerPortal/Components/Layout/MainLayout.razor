@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

<AuthorizeView>
	<Authorized>
		<TopBar />
		<main style="padding: 20px;">
			@Body
		</main>
	</Authorized>
    
	<NotAuthorized>
		<TopBar />
		<Login />
	</NotAuthorized>
</AuthorizeView>

